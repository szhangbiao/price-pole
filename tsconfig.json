{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"lib": ["ES2022"],
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"types": [
			"./worker-configuration.d.ts",
			"node"
		]
	},
	"exclude": [
		"my-first-worker/**/*",
		"node_modules/**/*"
	]
}
